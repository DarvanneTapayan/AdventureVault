{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's avatar URL" },
        "bio": { "type": "string", "description": "User's biography" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation date" }
      },
      "required": ["uid", "displayName", "email", "createdAt"]
    },
    "Adventure": {
      "title": "Adventure",
      "description": "An adventure post with media",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Document ID" },
        "userId": { "type": "string", "description": "Author's UID" },
        "authorName": { "type": "string", "description": "Author's display name" },
        "authorPhoto": { "type": "string", "description": "Author's photo URL" },
        "title": { "type": "string", "description": "Adventure title" },
        "description": { "type": "string", "description": "Adventure description" },
        "location": { "type": "string", "description": "Adventure location" },
        "date": { "type": "string", "format": "date", "description": "Adventure date" },
        "media": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "type": { "type": "string", "enum": ["image", "video"] },
              "thumbnail": { "type": "string", "format": "uri" }
            }
          },
          "description": "List of media files"
        },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Adventure tags" },
        "likesCount": { "type": "number", "description": "Number of likes" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Post creation date" }
      },
      "required": ["userId", "title", "media", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on an adventure",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Commenter's UID" },
        "userName": { "type": "string", "description": "Commenter's name" },
        "userPhoto": { "type": "string", "description": "Commenter's photo" },
        "text": { "type": "string", "description": "Comment text" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Comment date" }
      },
      "required": ["userId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/adventures/{adventureId}": {
      "schema": "Adventure",
      "description": "Adventure posts"
    },
    "/adventures/{adventureId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on adventures"
    },
    "/adventures/{adventureId}/likes/{userId}": {
      "schema": { "type": "object", "properties": { "createdAt": { "type": "string", "format": "date-time" } } },
      "description": "Likes on adventures"
    }
  }
}
